        <!-- Governance boundary around the curated / shared / semantic / AI zones.
             INFERRED: this box existed in the source file with no label, no fill,
             and was declared first (so the platform swimlane's background painted
             over it and it never actually rendered). Position lines up almost
             exactly around Silver/Gold/Semantic/AI & Cortex, so it reads as an
             intended governance perimeter. Rename or delete if that's not right. -->
        <mxCell id="YxopGKdeuyvlYZzn7uxj-4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 4;fillColor=none;strokeColor=#B85450;strokeWidth=2;verticalAlign=top;align=center;fontStyle=1;fontSize=11;fontColor=#B85450;spacingTop=6;" value="Horizon-Governed Zone (RBAC, Masking, Lineage)" vertex="1">
          <mxGeometry height="280" width="740" x="140" y="460" as="geometry" />
        </mxCell>

